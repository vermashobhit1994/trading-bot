# Binance Demo Trading API credentials (https://www.binance.com/en/demo-trading)
# Same demo key works for Spot and Futures, but each product has its own base URL.
BINANCE_API_KEY=your_demo_api_key
SECRET_KEY=your_demo_api_secret

# testnet | mainnet (default: testnet)
TRADING_ENV=testnet

# USDT-M Futures demo REST base URL (official per Binance Futures docs)
# Do NOT use https://demo-api.binance.com/api here — that is Spot demo only.
BINANCE_FUTURES_BASE_URL=https://demo-fapi.binance.com

# Signed request validity window in milliseconds
RECV_WINDOW=5000

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
