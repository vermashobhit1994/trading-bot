# =============================================================================
# DEMO / TESTNET (virtual funds) — default, safe for learning
# =============================================================================
# Create keys: https://www.binance.com/en/demo-trading -> API Management
# BINANCE_API_KEY=your_demo_api_key
# SECRET_KEY=your_demo_api_secret
# TRADING_ENV=testnet
# BINANCE_FUTURES_BASE_URL=https://demo-fapi.binance.com
# CONFIRM_LIVE_TRADING=false

# =============================================================================
# LIVE MAINNET (REAL MONEY) — only when you intend to trade for real
# =============================================================================
# Create keys: https://www.binance.com -> Profile -> API Management
# Enable Futures trading permission ONLY. Never enable withdrawals.
# Use IP whitelist. Use separate keys from demo.
#
# BINANCE_API_KEY=your_mainnet_api_key
# SECRET_KEY=your_mainnet_api_secret
# TRADING_ENV=mainnet
# BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
# CONFIRM_LIVE_TRADING=true

# Signed request validity window in milliseconds
RECV_WINDOW=5000

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
